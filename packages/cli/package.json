    "claude-code",
    "ai-agent",
    "agent-tools",
    "code-intelligence",
    "code-analysis",
    "codebase",
    "visualization",
    "typescript",
    "javascript",
    "ast",
    "dependency-graph",
    "static-analysis",
    "architecture"
  ],
  "license": "MIT",
  "author": "Prajeevan",
  "homepage": "https://github.com/Prajeevan/codinflow#readme",
  "repository": {
    "type": "git",
